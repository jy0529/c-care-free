<Window x:Class="CDriveCleanupMaster.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:CDriveCleanupMaster.App.ViewModels"
        xmlns:converters="clr-namespace:CDriveCleanupMaster.App.Converters"
        xmlns:helpers="clr-namespace:CDriveCleanupMaster.App.Helpers"
        xmlns:controls="clr-namespace:CDriveCleanupMaster.App.Controls"
        mc:Ignorable="d"
        Title="{x:Static helpers:AppBrandLogo.ProductName}"
        Width="1280"
        Height="820"
        MinWidth="1100"
        MinHeight="720"
        Background="{StaticResource PageBackgroundBrush}">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource HeaderBackgroundBrush}"
                Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <controls:AppLogoControl LogoSize="42" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static helpers:AppBrandLogo.ProductName}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#D8E4F2"
                                   FontSize="13"
                                   Text="{Binding DriveSummaryText}" />
                    </StackPanel>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="#D8E4F2"
                           FontSize="13"
                           Text="{Binding StatusText}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource SidebarBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrushLight}"
                    BorderThickness="0,0,1,0">
                <StackPanel Margin="0,12,0,0">
                    <Button Command="{Binding SelectCleanupNavCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCleanupNavSelected}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource NavSelectedBackgroundBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <Grid Width="28" Height="28">
                                <Border Width="28"
                                        Height="28"
                                        CornerRadius="8"
                                        Background="{StaticResource AccentBrush}" />
                                <Viewbox Width="16" Height="16">
                                    <Path Data="{x:Static helpers:CleanupIconCatalog.NavCleanupIcon}"
                                          Stretch="Uniform"
                                          Stroke="White"
                                          StrokeThickness="1.6"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round" />
                                </Viewbox>
                            </Grid>
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="11"
                                       TextAlignment="Center"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="垃圾" />
                            <TextBlock FontSize="11"
                                       TextAlignment="Center"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="清理" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       Foreground="{StaticResource AccentBrush}"
                                       Text="{Binding CleanupNavBadge}" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SelectLargeFilesNavCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLargeFilesNavSelected}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource NavSelectedBackgroundBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <Grid Width="28" Height="28">
                                <Border Width="28"
                                        Height="28"
                                        CornerRadius="8"
                                        Background="{StaticResource AccentBlueBrush}" />
                                <Viewbox Width="16" Height="16">
                                    <Path Data="{x:Static helpers:CleanupIconCatalog.NavLargeFilesIcon}"
                                          Stretch="Uniform"
                                          Stroke="White"
                                          StrokeThickness="1.6"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round" />
                                </Viewbox>
                            </Grid>
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="11"
                                       TextAlignment="Center"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="大文件" />
                            <TextBlock FontSize="11"
                                       TextAlignment="Center"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="搬家" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       Foreground="{StaticResource AccentBlueBrush}"
                                       Text="{Binding LargeFileNavBadge}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="20,16,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Style="{StaticResource MetricCardStyle}"
                            Margin="0"
                            Visibility="{Binding IsCleanupNavSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="可释放垃圾"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="14" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding ReclaimableText}"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="0"
                            Style="{StaticResource MetricCardStyle}"
                            Margin="0"
                            Visibility="{Binding IsLargeFilesNavSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="大文件数量"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="14" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding LargeFileCountText}"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource AccentBlueBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1"
                            Style="{StaticResource MetricCardStyle}"
                            Margin="0"
                            Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="扫描进度"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="14" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding ScanPhaseText}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,14,0,0"
                        Padding="18"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrushLight}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,16,0"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsLargeFilesNavSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock VerticalAlignment="Center"
                                           Margin="0,0,12,0"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           Text="大文件阈值" />
                                <ComboBox Width="120"
                                          Margin="0,0,16,0"
                                          VerticalAlignment="Center"
                                          ItemsSource="{Binding ThresholdOptions}"
                                          SelectedItem="{Binding SelectedThreshold}"
                                          DisplayMemberPath="Label"
                                          IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBooleanConverter}}" />
                                <TextBlock VerticalAlignment="Center"
                                           Margin="0,0,12,0"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           Text="显示数量" />
                                <ComboBox Width="120"
                                          VerticalAlignment="Center"
                                          ItemsSource="{Binding CountLimitOptions}"
                                          SelectedItem="{Binding SelectedCountLimit}"
                                          DisplayMemberPath="Label"
                                          IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBooleanConverter}}" />
                            </StackPanel>
                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding ScanCleanupCommand}"
                                    Content="扫描垃圾项"
                                    Visibility="{Binding IsCleanupNavSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding ScanLargeFilesCommand}"
                                    Content="扫描大文件"
                                    Visibility="{Binding IsLargeFilesNavSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Margin="20,0,0,0"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ProgressBar Width="240"
                                         Height="8"
                                         Maximum="100"
                                         Value="{Binding ScanProgress, Mode=OneWay}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,14,0,0"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrushLight}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="16">
                    <Grid>
                        <Grid Visibility="{Binding IsCleanupNavSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="17"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="点击「扫描垃圾项」查看可清理内容"
                                       Visibility="{Binding ShowCleanupList, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}" />

                            <Grid Visibility="{Binding ShowCleanupList, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <ScrollViewer Grid.Row="0"
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding CleanupCategories}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type viewModels:CleanupCategoryItemViewModel}">
                                                <Border Margin="0,0,0,12"
                                                        Padding="14"
                                                        Background="#FAFBFC"
                                                        BorderBrush="{StaticResource BorderBrushLight}"
                                                        BorderThickness="1"
                                                        CornerRadius="10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="40"
                                                                Height="40"
                                                                CornerRadius="10"
                                                                Background="{Binding IconBackground}">
                                                            <Viewbox Width="22" Height="22">
                                                                <Path Data="{Binding IconGeometry}"
                                                                      Stretch="Uniform"
                                                                      Stroke="White"
                                                                      StrokeThickness="1.8"
                                                                      StrokeStartLineCap="Round"
                                                                      StrokeEndLineCap="Round" />
                                                            </Viewbox>
                                                        </Border>
                                                        <StackPanel Grid.Column="1"
                                                                    Margin="12,0,8,0"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock FontSize="16"
                                                                       FontWeight="Bold"
                                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                                       Text="{Binding DisplayName}" />
                                                            <TextBlock Margin="0,4,0,0"
                                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                                       Text="{Binding Description}"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Margin="0,6,0,0"
                                                                       Foreground="#B7791F"
                                                                       Text="{Binding RiskLevelText, StringFormat=风险：{0}}" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Right">
                                                            <CheckBox IsChecked="{Binding IsSelected}"
                                                                      HorizontalAlignment="Right"
                                                                      Foreground="{StaticResource AccentBrush}" />
                                                            <TextBlock Margin="0,8,0,0"
                                                                       FontSize="17"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource AccentBrush}"
                                                                       Text="{Binding SizeText}" />
                                                            <TextBlock Margin="0,2,0,0"
                                                                       HorizontalAlignment="Right"
                                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                                       Text="{Binding FileCountText}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <Border Grid.Row="1"
                                        Margin="0,12,0,0"
                                        Padding="16,12"
                                        Background="#FFF8F0"
                                        BorderBrush="#F5D0A9"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Grid>
                                        <TextBlock VerticalAlignment="Center"
                                                   FontSize="16"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   Text="{Binding SelectedCleanupBytesText, StringFormat=已选择可释放：{0}}" />
                                        <Button HorizontalAlignment="Right"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Command="{Binding ExecuteCleanupCommand}"
                                                Content="立即清理" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid Visibility="{Binding IsLargeFilesNavSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="17"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="点击「扫描大文件」查找占用空间的文件"
                                       Visibility="{Binding ShowLargeFileList, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}" />

                            <Grid Visibility="{Binding ShowLargeFileList, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                    <TextBlock Margin="0,0,0,8"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Text="正在扫描，大文件将实时显示在下方..."
                                               Visibility="{Binding IsLargeFileScanning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="0,0,12,0"
                                                Command="{Binding MoveSelectedLargeFileCommand}"
                                                Content="搬到目录" />
                                        <Button Style="{StaticResource OutlineButtonStyle}"
                                                Command="{Binding OpenSelectedLargeFileLocationCommand}"
                                                Content="打开位置" />
                                    </StackPanel>
                                </StackPanel>
                                <DataGrid Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding LargeFiles}"
                                          SelectedItem="{Binding SelectedLargeFile}"
                                          GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column"
                                          BorderBrush="{StaticResource BorderBrushLight}"
                                          Background="White"
                                          Foreground="{StaticResource PrimaryTextBrush}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="200" Binding="{Binding Name}" Header="文件名" />
                                        <DataGridTextColumn Width="*" Binding="{Binding FilePath}" Header="路径" />
                                        <DataGridTextColumn Width="120"
                                                              Binding="{Binding SizeText}"
                                                              SortMemberPath="Bytes"
                                                              Header="大小" />
                                        <DataGridTextColumn Width="2*" Binding="{Binding RelocationHintText}" Header="搬家建议" />
                                        <DataGridTextColumn Width="100" Binding="{Binding Extension}" Header="类型" />
                                        <DataGridTextColumn Width="160" Binding="{Binding ModifiedText}" Header="最后修改" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
