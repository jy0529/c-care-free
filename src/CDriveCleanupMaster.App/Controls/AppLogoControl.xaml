<UserControl x:Class="CDriveCleanupMaster.App.Controls.AppLogoControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:CDriveCleanupMaster.App.Helpers"
             x:Name="Root"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             Width="{Binding LogoSize, ElementName=Root}"
             Height="{Binding LogoSize, ElementName=Root}">
    <Image Source="{x:Static helpers:AppBrandLogo.LogoImage}"
           Stretch="Uniform"
           RenderOptions.BitmapScalingMode="HighQuality" />
</UserControl>
